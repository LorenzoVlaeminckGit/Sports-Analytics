{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "Generated analysis report from the generative module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "prompt": { "type": "string" },
        "result": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "userId": { "type": "string" }
      },
      "required": ["moduleId", "prompt", "result", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "User specific generated analysis reports"
    }
  }
}
